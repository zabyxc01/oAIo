          "node_type": "oAIo/llm-model",
          "action_endpoint": "/services/ollama/models/{id}/load",
          "action_method": "POST"
        }
      ]
    },
    "open-webui": {
      "container": "open-webui",
      "port": 3000,
      "vram_est_gb": 0,
      "ram_est_gb": 1.3,
