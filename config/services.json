      "group": "oLLM",
      "memory_mode": "ram",
      "boot_with_system": true,
      "description": "LLM chat UI",
      "capabilities": []
    },
    "kokoro-tts": {
      "container": "kokoro-tts",
      "port": 8000,
      "vram_est_gb": 0,
      "ram_est_gb": 0.8,
      "priority": 2,
      "limit_mode": "soft",
      "group": "oAudio",
      "memory_mode": "ram",
      "boot_with_system": true,
