{
  "services": {
    "ollama": {
      "container": "ollama",
      "port": 11434,
      "vram_est_gb": 7.5,
      "ram_est_gb": 7.2,
      "priority": 1,
      "limit_mode": "soft",
      "group": "oLLM",
      "memory_mode": "vram",
      "bus_preference": "sata",
      "boot_with_system": true,
      "description": "LLM backend",
      "capabilities": [
        {
          "type": "models",
          "label": "LLM Model",
