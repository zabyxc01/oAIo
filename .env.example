# oAIo — environment configuration example
# Copy to .env and fill in your values.
# All variables use :-default fallback in docker-compose.yml so this file is optional
# on existing installs. Run install.sh to generate .env automatically.

# ── GPU ───────────────────────────────────────────────────────────────────────
# AMD RDNA3 (gfx1100 = RX 7900 XT/XTX): keep as-is
# AMD RDNA2 (gfx1030 = RX 6800 XT):     PYTORCH_ROCM_ARCH=gfx1030 / HSA=10.3.0
# AMD CDNA2 (gfx90a = MI250):            PYTORCH_ROCM_ARCH=gfx90a  / HSA=9.0.10
PYTORCH_ROCM_ARCH=gfx1100
HSA_OVERRIDE_GFX_VERSION=11.0.0

# ── Paths ─────────────────────────────────────────────────────────────────────
OAIO_SYMLINK_ROOT=/mnt/oaio

# ── Network binding ──────────────────────────────────────────────────────────
# Bind address for all services (default: 127.0.0.1 = localhost only)
# Set to 0.0.0.0 to expose on all interfaces
# Set to your Tailscale IP (e.g., 100.99.194.124) for VPN-only access
OAIO_BIND=127.0.0.1

# ── API Authentication ──────────────────────────────────────────────────────
# Optional Bearer token for oLLMo (9000) and oAudio (8002) APIs.
# If unset or empty, APIs are open (no auth required — backward compatible).
# OAIO_API_TOKEN=your-secret-token-here

# ── Service ports (for reference) ─────────────────────────────────────────────
OAIO_API_PORT=9000
OAIO_AUDIO_PORT=8002
OLLAMA_PORT=11434
OPEN_WEBUI_PORT=3000
KOKORO_PORT=8000
RVC_PROXY_PORT=8001
RVC_GRADIO_PORT=7865
F5_PORT=7860
COMFYUI_PORT=8188
